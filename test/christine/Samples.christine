(* Christine Samples ported from frank.ml *)

Module Samples.

Inductive Bool :=
| False
| True.

Inductive Nat :=
| Zero
| Succ (n: Nat).

Definition plus (m: Nat) (n: Nat) : Nat :=
  match m with
  | Zero => n
  | Succ k => Succ (plus k n)
  end.

Inductive Tree (A: Type) :=
| Leaf
| Node (v: A) (l: Tree A) (r: Tree A).

Inductive Empty := .

Inductive Unit := tt.

(* W-types *)
Inductive W (A: Type) (B: forall (x: A), Type) :=
| Sup (x: A) (f: forall (y: B x), W A B).

(* Nat as W-type *)
(* A = Bool, B False = Empty, B True = Unit *)
Definition B_nat (b: Bool) : Type :=
  match b with
  | False => Empty
  | True => Unit
  end.

Inductive WNat :=
| WNat (w: W Bool B_nat).

Definition zero_w : W Bool B_nat :=
  Sup Bool B_nat False (fun (e: Empty) => match e with end).

Definition succ_w (n: W Bool B_nat) : W Bool B_nat :=
  Sup Bool B_nat True (fun (u: Unit) => n).
