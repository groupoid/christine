(* Synthetic Geometry Axioms and Pythagorean Theorem *)

Module Test.Pythagorean.

import Prelude.
import Data.Eq.

(* Define Point as an abstract type (axiom) *)
Definition Point : Type.

(* Define congruence of segments, written as AB ≡ CD *)
Definition Cong (A: Point) (B: Point) (C: Point) (D: Point) : Type.

(* Define betweenness: B is between A and C, written A-B-C *)
Definition Bet (A: Point) (B: Point) (C: Point) : Type.

(* Define perpendicularity: line AB ⊥ CD *)
Definition Perp (A: Point) (B: Point) (C: Point) (D: Point) : Type.

(* Axioms *)
Definition Cong_refl (A: Point) (B: Point) : Cong A B A B.
Definition Cong_sym (A: Point) (B: Point) (C: Point) (D: Point) (p: Cong A B C D) : Cong C D A B.
Definition Cong_trans (A: Point) (B: Point) (C: Point) (D: Point) (E: Point) (F: Point) (p: Cong A B C D) (q: Cong C D E F) : Cong A B E F.

Definition Cong_identity (A: Point) (B: Point) (C: Point) (p: Cong A B C C) : Eq Point A B.

Definition Bet_identity (A: Point) (B: Point) (p: Bet A B A) : Eq Point A B.
Definition Bet_sym (A: Point) (B: Point) (C: Point) (p: Bet A B C) : Bet C B A.

Definition Perp_exists (A: Point) (B: Point) : Sigma Point (fun (C: Point) => Sigma (Perp A B A C) (fun (p: Perp A B A C) => (Eq Point A C -> Empty))).

Definition RightTriangle (A: Point) (B: Point) (C: Point) : Type :=
  Sigma (Bet A B C -> Empty) (fun (p1: Bet A B C -> Empty) =>
  Sigma (Bet B C A -> Empty) (fun (p2: Bet B C A -> Empty) =>
  Sigma (Bet C A B -> Empty) (fun (p3: Bet C A B -> Empty) =>
    Perp A B B C))).

Definition Square (A: Point) (B: Point) (C: Point) (D: Point) : Type :=
  Sigma (Cong A B B C) (fun (p1: Cong A B B C) =>
  Sigma (Cong B C C D) (fun (p2: Cong B C C D) =>
  Sigma (Cong C D D A) (fun (p3: Cong C D D A) =>
  Sigma (Perp A B B C) (fun (p4: Perp A B B C) =>
  Sigma (Perp B C C D) (fun (p5: Perp B C C D) =>
  Sigma (Perp C D D A) (fun (p6: Perp C D D A) =>
    Perp D A A B)))))).

Definition Pythagorean_theorem (A: Point) (B: Point) (C: Point) : Type :=
  RightTriangle A B C ->
  Sigma Point (fun (P: Point) =>
  Sigma Point (fun (Q: Point) =>
  Sigma Point (fun (R: Point) =>
  Sigma Point (fun (S: Point) =>
  Sigma (Square A B P Q) (fun (s1: Square A B P Q) =>
    Sigma Point (fun (T: Point) =>
    Sigma Point (fun (U: Point) =>
    Sigma Point (fun (V: Point) =>
    Sigma Point (fun (W: Point) =>
    Sigma (Square B C T U) (fun (s2: Square B C T U) =>
      Sigma Point (fun (X: Point) =>
      Sigma Point (fun (Y: Point) =>
      Sigma Point (fun (Z: Point) =>
      Square A C X Y))))))))))))).

Definition py_thm_axiom (A: Point) (B: Point) (C: Point) (HRT: RightTriangle A B C) : Pythagorean_theorem A B C.

Theorem pythagorean_synthetic (A: Point) (B: Point) (C: Point) (HRT: RightTriangle A B C) : Pythagorean_theorem A B C.
Proof.
  intro HRT'.
  exact py_thm_axiom A B C HRT'.
Qed.
