(* Test cases for Data.List functionality *)

Module Test.List.

import Data.List.
import Data.Bool.
import Data.Nat.

Definition l1 : List Nat :=
  Cons Nat (Succ Zero) (Cons Nat (Succ (Succ Zero)) (Nil Nat)).

Definition l2 : List Nat :=
  Cons Nat (Succ (Succ (Succ Zero))) (Nil Nat).

(* Should be Cons (Succ Zero) (Cons (Succ (Succ Zero)) (Cons (Succ (Succ (Succ Zero))) Nil)) *)
Definition test_append : List Nat := append Nat l1 l2.

(* Should be Cons (Succ (Succ Zero)) (Cons (Succ Zero) Nil) *)
Definition test_reverse : List Nat := reverse Nat l1.

(* Should be Cons (Succ (Succ Zero)) (Cons (Succ (Succ (Succ Zero))) Nil) *)
Definition test_map : List Nat := map Nat Nat (fun (x: Nat) => Succ x) l1.

(* Should be Succ (Succ (Succ Zero)) *)
Definition test_foldr : Nat := foldr Nat Nat plus Zero l1.

Definition is_gt_one (x: Nat) : Bool :=
  match x with
  | Zero => False
  | Succ y =>
    match y with
    | Zero => False
    | Succ z => True
    end
  end.

(* Should be Cons (Succ (Succ (Succ Zero))) Nil *)
Definition test_filter : List Nat := filter Nat is_gt_one l1.

(* Should be Cons (Succ (Succ (Succ (Succ Zero)))) Nil *)
Definition test_zipWith : List Nat := zipWith Nat Nat Nat plus l1 l2.
