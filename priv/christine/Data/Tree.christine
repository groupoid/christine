(* Polymorphic binary trees for Christine *)

Module Data.Tree.

import Data.Nat

Inductive Tree (A: Type) :=
| Leaf
| Node (left: Tree A) (value: A) (right: Tree A).

Definition depth (A: Type) (t: Tree A) : Nat :=
  match t with
  | Leaf => Zero
  | Node l v r => Succ (max (depth A l) (depth A r))
  end.
