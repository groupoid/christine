(* Sigma Types (Dependent Pairs) for Christine *)

Module Data.Sigma.

Inductive Sigma (A: Type) (B: forall (x: A), Type) :=
| DPair (x: A) (y: B x).

Definition pr1 (A: Type) (B: forall (x: A), Type) (p: Sigma A B) : A :=
  match p with
  | DPair x y => x
  end.

Definition pr2 (A: Type) (B: forall (x: A), Type) (p: Sigma A B) : B (pr1 A B p) :=
  match p with
  | DPair x y => y
  end.
